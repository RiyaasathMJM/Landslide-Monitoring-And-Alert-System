#include <avr/io.h>
#include <util/delay.h>
#include <stdio.h>

#define DHT_PIN PD2

// ---------- UART ----------
void UART_init() {
    UBRR0H = 0;
    UBRR0L = 103; // 9600 baud @16MHz
    UCSR0B = (1 << TXEN0);
    UCSR0C = (1 << UCSZ01) | (1 << UCSZ00);
}

void UART_tx(char data) {
    while (!(UCSR0A & (1 << UDRE0)));
    UDR0 = data;
}

void UART_print(char *str) {
    while (*str) UART_tx(*str++);
}

// ---------- ADC ----------
void ADC_init() {
    ADMUX = (1 << REFS0);
    ADCSRA = (1 << ADEN) | (1 << ADPS2) | (1 << ADPS1);
}

uint16_t ADC_read(uint8_t ch) {
    ADMUX = (ADMUX & 0xF0) | ch;
    ADCSRA |= (1 << ADSC);
    while (ADCSRA & (1 << ADSC));
    return ADC;
}

// ---------- DHT11 ----------
uint8_t DHT_read(uint8_t *temperature, uint8_t *humidity) {
    uint8_t data[5] = {0};

    // Start signal
    DDRD |= (1 << DHT_PIN);
    PORTD &= ~(1 << DHT_PIN);
    _delay_ms(18);

    PORTD |= (1 << DHT_PIN);
    _delay_us(30);
    DDRD &= ~(1 << DHT_PIN);

    // Wait for response
    _delay_us(40);
    if (PIND & (1 << DHT_PIN)) return 0;

    _delay_us(80);
    if (!(PIND & (1 << DHT_PIN))) return 0;

    _delay_us(80);

    // Read 40 bits
    for (uint8_t i = 0; i < 40; i++) {
        while (!(PIND & (1 << DHT_PIN))); // wait HIGH
        _delay_us(30);

        if (PIND & (1 << DHT_PIN))
            data[i / 8] |= (1 << (7 - (i % 8)));

        while (PIND & (1 << DHT_PIN)); // wait LOW
    }

    // Checksum
    if ((data[0] + data[1] + data[2] + data[3]) != data[4])
        return 0;

    *humidity = data[0];
    *temperature = data[2];

    return 1;
}

// ---------- MAIN ----------
int main(void) {
    UART_init();
    ADC_init();

    DDRD &= ~(1 << PD3);   // Vibration input
    PORTD |= (1 << PD3);   // Pull-up

    char buffer[80];
    uint8_t temp, hum;

    while (1) {
        uint16_t soil = ADC_read(0);

        if (DHT_read(&temp, &hum)) {
            snprintf(buffer, sizeof(buffer),
                "T:%dC H:%d%% Soil:%d ",
                temp, hum, soil);
        } else {
            snprintf(buffer, sizeof(buffer),
                "DHT Error Soil:%d ",
                soil);
        }

        if (!(PIND & (1 << PD3))) {
            UART_print("Vibration!\r\n");
        } else {
            UART_print("No Vib ");
            UART_print(buffer);
            UART_print("\r\n");
        }

        _delay_ms(2000);
    }
}